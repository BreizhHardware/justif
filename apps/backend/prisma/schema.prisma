generator client {
  provider           = "prisma-client"
  output             = "../src/generated"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

model Expense {
  id               String   @id @default(cuid())
  date             DateTime
  fournisseur      String?
  numero_reference String?
  categorie        String   @default("Autre")
  description      String?
  devise           String   @default("EUR")
  montant_ttc      Float?
  montant_ht       Float?
  tva              Float?
  montant_ttc_eur  Float?
  montant_ht_eur   Float?
  taux_change      Float?
  taux_change_date String?
  pays             String?
  langue_detectee  String?
  fichier          String?
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportedIn ExpenseReportItem[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  expenses  Expense[]
  reports   ExpenseReport[]
  auditLogs AuditLog[]
  roles     UserRole[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users       UserRole[]
}

model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String // value from the Permission union in src/lib/permissions.ts

  @@unique([roleId, permission])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
}

// AuditLog records sensitive actions for compliance and investigation purposes.
// GDPR note: userId uses SetNull on delete — logs are pseudonymised when a user
// exercises their right to erasure while preserving the audit trail integrity.
// IP addresses stored here are personal data and must be disclosed in the privacy policy.
model AuditLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  action       String   // e.g. "expense.create", "user.update", "export.zip"
  entityType   String?  // "Expense" | "User" | "Setting" | "ExpenseReport"
  entityId     String?  // ID of the affected entity
  targetUserId String?  // Set when an admin acts on another user's data
  metadata     String?  // JSON string — no passwords, no API key values, minimal PII
  ip           String?  // Client IP (GDPR: personal data)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ExpenseReport {
  id         String   @id @default(cuid())
  name       String
  periodFrom String?
  periodTo   String?
  createdAt  DateTime @default(now())

  userId String
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  ExpenseReportItem[]
}

model ExpenseReportItem {
  id String @id @default(cuid())

  reportId String
  report   ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  expenseId String
  expense   Expense      @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([reportId, expenseId])
}

model Setting {
  key   String @id @unique
  value String
}
