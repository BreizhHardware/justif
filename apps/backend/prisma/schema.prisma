generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id               String   @id @default(cuid())
  date             DateTime
  fournisseur      String?
  categorie        String   @default("Autre")
  description      String?
  devise           String   @default("EUR")
  montant_ttc      Float?
  montant_ht       Float?
  tva              Float?
  montant_ttc_eur  Float?
  montant_ht_eur   Float?
  taux_change      Float?
  taux_change_date String?
  pays             String?
  langue_detectee  String?
  fichier          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}

model Setting {
  key   String @id @unique
  value String
}
