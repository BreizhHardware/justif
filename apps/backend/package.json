    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "prisma": "^7.0.0",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
