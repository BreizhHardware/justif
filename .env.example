# ── Auth ──────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars

# ── OCR (configurable aussi depuis l'UI) ──────
OCR_PROVIDER=cloud           # cloud | local
MISTRAL_API_KEY=
MISTRAL_MODEL=pixtral-12b-2409
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

# ── Devise par défaut ─────────────────────────
DEFAULT_CURRENCY=EUR

# ── Image Docker unifiée ───────────────────────
# Port public unique (frontend + API derrière le proxy intégré).
PORT=3000

# ── Backend (interne au conteneur, ne pas exposer) ─
DATABASE_URL=file:./db/justif.db
UPLOAD_DIR=./uploads