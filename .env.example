# ── Auth ──────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars

# ── Default Currency ─────────────────────────
DEFAULT_CURRENCY=EUR

# ── Unified docker image ───────────────────────
# Unique port for the backend and frontend, to be used in docker-compose
PORT=3000

# ── Backend ─
DATABASE_URL=file:./db/justif.db
UPLOAD_DIR=./uploads