{
  "name": "justif",
  "version": "0.1.5",
  "private": true,
  "description": "Justif — gestion de notes de frais open source et auto-hébergeable",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --parallel --filter ./apps/* run dev",
    "build": "pnpm --filter ./apps/* run build",
    "lint": "oxlint . && oxfmt .",
    "format": "oxfmt .",
    "db:migrate": "pnpm --filter backend run db:migrate",
    "db:generate": "pnpm --filter backend run db:generate"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
